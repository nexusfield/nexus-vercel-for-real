# =============================================================================
# NEXUS — Environment Variables
# Copy to .env.local and fill in values. Never commit .env.local.
# =============================================================================

# --- NextAuth (Google OAuth) ---
# Session/encryption secret. Generate with: npx auth secret
# NextAuth uses AUTH_SECRET (or NEXTAUTH_SECRET) for signing tokens.
AUTH_SECRET=

# Google OAuth credentials from Google Cloud Console
# Create at: https://console.cloud.google.com/apis/credentials
# Add redirect URIs:
# - http://localhost:3000/api/auth/callback/google
# - https://<your-vercel-domain>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- AI APIs ---
# Required for Claude (chat, intake, reasoning agents)
ANTHROPIC_API_KEY=

# Required for Gemini chat models and embeddings (navigation/intake)
GEMINI_API_KEY=

# --- Supabase (Postgres + pgvector) ---
# Project URL and anon key from Supabase dashboard:
# Settings -> API -> Project URL / anon public key
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Optional: service role key (bypasses RLS). Required for Knowledge Folders to work.
# Settings -> API -> service_role secret. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Unused; kept for potential future use
OPENAI_API_KEY=

# --- Optional ---
# Backup interval in ms (default 3600000 = 1 hour). Min 60000.
# NEXUS_BACKUP_INTERVAL_MS=
